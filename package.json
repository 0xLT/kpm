{
  "name": "knowledge-package-manager",
  "version": "0.1.0",
  "description": "Local CLI MVP for installable, versioned Markdown knowledge packages.",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "kpm": "./dist/cli.js"
