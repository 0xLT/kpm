{
  "name": "knowledge-package-manager",
  "version": "2.0.0-alpha.1",
  "description": "npm-style package manager for wiki-linked Markdown knowledge bases.",
  "license": "MIT",
  "author": "0xLT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xLT/kpm.git"
  },
  "bugs": {
    "url": "https://github.com/0xLT/kpm/issues"
  },
  "homepage": "https://github.com/0xLT/kpm#readme",
  "keywords": [
    "markdown",
    "obsidian",
    "knowledge-management",
    "knowledge-base",
    "cli",
    "typescript",
    "llm",
    "package-manager",
    "wikilinks"
  ],
  "type": "module",
  "files": [
    "dist/**/*.js",
    "README.md"
  ],
  "bin": {
    "kpm": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/cli.js",
    "test": "npm run build && vitest run",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm test && npm run typecheck"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "picomatch": "^4.0.2",
    "remark": "^15.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "remark-wiki-link": "^2.0.1",
    "semver": "^7.6.3",
    "tar": "^7.4.3",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "@types/picomatch": "^4.0.0",
    "@types/semver": "^7.7.0",
    "@types/tar": "^6.1.13",
    "typescript": "^5.6.3",
    "vitest": "^4.1.6",
    "yaml": "^2.9.0"
  }
}
